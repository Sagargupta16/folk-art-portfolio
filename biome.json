{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"src/**/*.{ts,tsx,js,jsx}",
			"scripts/**/*.{js,mjs,ts}",
			"vite.config.ts",
			"index.html",
			"*.json",
			"!**/dist",
			"!**/node_modules",
			"!**/.astro",
			"!**/_opt",
			"!pnpm-lock.yaml",
			"!tsconfig.tsbuildinfo"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noArrayIndexKey": "off",
				"noExplicitAny": "warn"
			},
			"a11y": {
				"recommended": true,
				"useKeyWithClickEvents": "off",
				"useSemanticElements": "off"
			},
			"style": {
				"useImportType": "warn",
				"noNonNullAssertion": "off"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
