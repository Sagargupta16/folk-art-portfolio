---
import { brand, contact } from '@/lib/site';
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-line)]">
  <div class="container-x flex flex-col items-start justify-between gap-3 py-10 sm:flex-row sm:items-center">
    <p class="t-display text-xl text-[var(--color-ink)]">{brand.title}</p>
    <div class="flex flex-wrap items-center gap-4 sm:gap-6">
      <a class="t-meta hover:text-[var(--color-accent)]" href={contact.instagram.url} target="_blank" rel="noopener noreferrer">
        Instagram
      </a>
      <a class="t-meta hover:text-[var(--color-accent)]" href={contact.email.url}>Email</a>
      <span class="t-meta">© {year}</span>
    </div>
  </div>
</footer>
