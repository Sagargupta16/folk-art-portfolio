---
import Section from '@/components/layout/Section.astro';
import { contact, sections } from '@/lib/site';

const items = [contact.instagram, contact.whatsapp, contact.email];
const c = sections.contact;
---
<Section id="contact" eyebrow={c.eyebrow} title={c.title} lead={c.lead}>
  <ul class="divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
    {
      items.map((it, i) => (
        <li class="reveal" style={`transition-delay:${i * 90}ms`}>
          <a
            class="group flex flex-wrap items-baseline justify-between gap-3 py-5 transition hover:text-[var(--color-accent)] sm:gap-6 sm:py-6"
            href={it.url}
            target={it.url.startsWith('http') ? '_blank' : undefined}
            rel={it.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <span class="t-meta">{it.label}</span>
            <span class="t-display break-all text-xl text-[var(--color-ink)] transition group-hover:text-[var(--color-accent)] sm:text-2xl md:text-3xl">
              {it.display}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</Section>
