---
// <picture> wrapper for catalog artworks. Uses pre-generated AVIF/WebP variants
// from public/_opt/artworks/ (created by scripts/optimize-images.mjs at prebuild).
// Falls back to the original .jpg in public/artworks/ for browsers without AVIF/WebP.

interface Props {
  /** filename from artworks.json, e.g. "radha-krishna.jpg" */
  filename: string;
  alt: string;
  /** import.meta.env.BASE_URL from the calling page */
  baseUrl: string;
  /** CSS class applied to the <img> element. img-fade is added automatically. */
  imgClass?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
  fetchpriority?: 'high' | 'low' | 'auto';
  /** <source sizes> attribute. Defaults match the 3-col gallery grid. */
  sizes?: string;
  /** Wrapper class on the <picture> element. */
  pictureClass?: string;
}

const {
  filename,
  alt,
  baseUrl,
  imgClass = '',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes = '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw',
  pictureClass = '',
} = Astro.props;

const slug = filename.replace(/\.(jpe?g|png)$/i, '');
const widths = [400, 800, 1200];
const optBase = `${baseUrl}_opt/artworks/${slug}`;
const origUrl = `${baseUrl}artworks/${filename}`;

const avifSrcset = widths.map((w) => `${optBase}-${w}.avif ${w}w`).join(', ');
const webpSrcset = widths.map((w) => `${optBase}-${w}.webp ${w}w`).join(', ');
---
<picture class={pictureClass}>
  <source type="image/avif" srcset={avifSrcset} sizes={sizes} />
  <source type="image/webp" srcset={webpSrcset} sizes={sizes} />
  <img
    src={origUrl}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={imgClass}
  />
</picture>
